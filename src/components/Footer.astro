---
import { siteConfig, navLinks } from '../data/site';
---

<footer class="bg-[#0B2545] text-white">
  <div class="divider-glow"></div>
  <div class="mx-auto grid w-full max-w-6xl gap-10 px-4 py-14 md:grid-cols-4 md:px-6">

    <!-- Brand -->
    <div class="space-y-4 md:col-span-1">
      <div class="flex items-center gap-3">
        <img src="/north-star-mark.svg" alt="North Star Digital" width="28" height="28" />
        <span class="text-lg font-bold">{siteConfig.name}</span>
      </div>
      <p class="text-sm text-[#8EA8C3]">{siteConfig.tagline}</p>
      <p class="text-xs text-[#8EA8C3]">📍 Waukesha, Wisconsin</p>
    </div>

    <!-- Pages -->
    <div>
      <h3 class="text-sm font-semibold uppercase tracking-wide text-[#C5D9FF]">Pages</h3>
      <ul class="mt-3 space-y-2 text-sm">
        {navLinks.map((link) => (
          <li><a href={link.href} class="text-[#8EA8C3] transition hover:text-white">{link.label}</a></li>
        ))}
      </ul>
    </div>

    <!-- Services -->
    <div>
      <h3 class="text-sm font-semibold uppercase tracking-wide text-[#C5D9FF]">Services</h3>
      <ul class="mt-3 space-y-2 text-sm text-[#8EA8C3]">
        <li>Website Design</li>
        <li>Local SEO</li>
        <li>CRM Systems</li>
        <li>Marketing Automation</li>
      </ul>
    </div>

    <!-- Contact -->
    <div>
      <h3 class="text-sm font-semibold uppercase tracking-wide text-[#C5D9FF]">Contact</h3>
      <ul class="mt-3 space-y-3 text-sm">
        <li>
          <a href={siteConfig.phoneHref} class="flex items-center gap-2 text-[#2E8BFF] font-bold hover:text-white transition text-base">
            📞 {siteConfig.phone}
          </a>
        </li>
        <li>
          <a href={`mailto:${siteConfig.email}`} class="text-[#8EA8C3] hover:text-white transition break-all">
            {siteConfig.email}
          </a>
        </li>
        <li class="pt-2">
          <a href={siteConfig.phoneHref} class="inline-block rounded-xl bg-[#2E8BFF] px-5 py-2.5 text-sm font-bold text-white transition hover:bg-[#1E7AEB]">
            Call Now — Free Consult
          </a>
        </li>
      </ul>
    </div>

  </div>
  <div class="border-t border-[#1A3A5C] px-4 py-5 text-center text-xs text-[#8EA8C3] md:px-6">
    © 2026 North Star Digital LLC · Waukesha, Wisconsin · All rights reserved
  </div>
</footer>
