---
interface Props {
  title: string;
  description: string;
  icon: 'website' | 'crm' | 'seo' | 'automation';
}

const { title, description, icon } = Astro.props;

const iconPaths = {
  website: 'M4 6h16M4 12h16M4 18h10',
  crm: 'M12 6v12M6 12h12',
  seo: 'M15 15l5 5M10 16a6 6 0 1 1 0-12 6 6 0 0 1 0 12Z',
  automation: 'M5 8h14M5 12h14M5 16h8'
};
---

<article class="rounded-xl border border-[#E3E8F1] bg-white p-6 shadow-sm transition hover:-translate-y-0.5 hover:shadow-md">
  <div class="mb-4 inline-flex h-11 w-11 items-center justify-center rounded-lg bg-[#EAF2FF] text-[#0B2545]">
    <svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" aria-hidden="true">
      <path d={iconPaths[icon]} stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
    </svg>
  </div>
  <h3 class="text-lg font-semibold text-[#0B2545]">{title}</h3>
  <p class="mt-2 text-sm leading-relaxed text-[#44506A]">{description}</p>
</article>
