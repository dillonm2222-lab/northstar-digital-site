---
import { navLinks, siteConfig } from '../data/site';
---

<!-- Top bar -->
<div class="hidden bg-[#0B2545] px-4 py-2 text-center text-xs text-[#8EA8C3] md:block">
  <div class="mx-auto flex max-w-6xl items-center justify-between">
    <span>📍 Headquartered in Waukesha, Wisconsin</span>
    <div class="flex items-center gap-6">
      <a href={`mailto:${siteConfig.email}`} class="hover:text-white transition">{siteConfig.email}</a>
      <a href={siteConfig.phoneHref} class="font-semibold text-[#2E8BFF] hover:text-white transition">{siteConfig.phone}</a>
    </div>
  </div>
</div>

<header class="sticky top-0 z-40 border-b border-[#E4E8F0] bg-white/95 backdrop-blur shadow-sm">
  <div class="mx-auto flex w-full max-w-6xl items-center justify-between px-4 py-3 md:px-6">
    <a href="/" class="flex items-center gap-3 text-base font-bold text-[#0B2545]">
      <img src="/north-star-mark.svg" alt="North Star Digital logo mark" width="32" height="32" />
      <span>North Star Digital</span>
    </a>

    <button
      type="button"
      id="nav-toggle"
      class="inline-flex items-center rounded-lg border border-[#D6DEEA] p-2 text-[#0B2545] hover:bg-[#F4F6FA] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[#2E8BFF] md:hidden"
      aria-expanded="false"
      aria-controls="mobile-nav"
    >
      <span class="sr-only">Toggle navigation menu</span>
      <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <path d="M4 7h16M4 12h16M4 17h16" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
      </svg>
    </button>

    <nav class="hidden md:flex md:items-center md:gap-8" aria-label="Primary">
      <ul class="flex items-center gap-7 text-sm font-medium">
        {navLinks.map((link) => (
          <li>
            <a href={link.href} class="text-[#1A1F2E] transition hover:text-[#2E8BFF]">{link.label}</a>
          </li>
        ))}
      </ul>
      <a
        href={siteConfig.phoneHref}
        class="btn-glow ml-2 inline-flex items-center gap-2 rounded-xl bg-[#2E8BFF] px-5 py-2.5 text-sm font-bold text-white transition hover:bg-[#1E7AEB]"
      >
        <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
        </svg>
        {siteConfig.phone}
      </a>
    </nav>
  </div>

  <nav id="mobile-nav" class="hidden border-t border-[#E4E8F0] bg-white px-4 py-4 md:hidden" aria-label="Mobile">
    <ul class="space-y-3 text-sm font-medium">
      {navLinks.map((link) => (
        <li>
          <a href={link.href} class="block rounded-md px-2 py-1.5 text-[#1A1F2E] transition hover:bg-[#F4F6FA] hover:text-[#0B2545]">{link.label}</a>
        </li>
      ))}
      <li class="pt-2 border-t border-[#E4E8F0]">
        <a href={siteConfig.phoneHref} class="block rounded-xl bg-[#2E8BFF] px-4 py-2.5 text-center text-sm font-bold text-white">{siteConfig.phone}</a>
      </li>
      <li>
        <a href={`mailto:${siteConfig.email}`} class="block px-2 py-1.5 text-center text-xs text-[#2E8BFF]">{siteConfig.email}</a>
      </li>
    </ul>
  </nav>
</header>

<script>
  const navToggle = document.querySelector('#nav-toggle');
  const mobileNav = document.querySelector('#mobile-nav');

  if (navToggle && mobileNav) {
    navToggle.addEventListener('click', () => {
      const isOpen = navToggle.getAttribute('aria-expanded') === 'true';
      navToggle.setAttribute('aria-expanded', String(!isOpen));
      mobileNav.classList.toggle('hidden');
    });
  }
</script>
