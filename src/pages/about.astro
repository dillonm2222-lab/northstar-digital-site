---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTA from '../components/CTA.astro';

const pageTitle = 'About Us | North Star Digital — Pewaukee, WI';
const description =
  'North Star Digital is a father-son digital agency in Pewaukee, Wisconsin. We help local contractors, plumbers, landscapers, and service businesses get more calls and grow online.';

const phone = '(262) 254-0128';
const phoneHref = 'tel:+12622540128';
---

<BaseLayout title={pageTitle} description={description} path="/about">

  <!-- HERO -->
  <section class="bg-[#0B2545] px-4 py-16 md:py-20">
    <div class="mx-auto max-w-4xl text-center">
      <p class="mb-3 text-xs font-semibold uppercase tracking-widest text-[#2E8BFF]">Pewaukee, Wisconsin</p>
      <h1 class="text-4xl font-bold text-white md:text-5xl">A Local Team That Actually Cares</h1>
      <p class="mx-auto mt-5 max-w-2xl text-lg text-[#8EA8C3]">
        We're not a faceless agency. We're Dillon and his Dad — two guys from Pewaukee who got tired of watching good local businesses get left behind online.
      </p>
    </div>
  </section>

  <!-- STORY -->
  <section class="px-4 py-20 md:py-24">
    <div class="mx-auto max-w-5xl">
      <div class="grid gap-12 md:grid-cols-2 md:items-center">
        <div>
          <p class="mb-2 text-xs font-semibold uppercase tracking-widest text-[#2E8BFF]">Our Story</p>
          <h2 class="text-3xl font-bold text-[#0B2545] md:text-4xl">Why We Started NSD</h2>
          <p class="mt-5 text-base leading-relaxed text-[#44506A]">
            We grew up watching small businesses in our community struggle online. Great contractors with bad websites. Good plumbers nobody could find on Google. Hardworking landscapers losing jobs to bigger companies with better marketing — not better work.
          </p>
          <p class="mt-4 text-base leading-relaxed text-[#44506A]">
            So we built North Star Digital to fix that. We combine real web development, local SEO, CRM systems, and AI automation — and we deliver it at a price that actually makes sense for a small business owner.
          </p>
          <p class="mt-4 text-base leading-relaxed text-[#44506A]">
            We're not trying to build a massive agency. We're trying to build a business we're proud of — one Wisconsin client at a time. When you work with us, you get our personal cell numbers, our full attention, and a team that genuinely wants to see your business grow.
          </p>
          <div class="mt-8">
            <a href={phoneHref} class="inline-flex items-center gap-2 rounded-xl bg-[#2E8BFF] px-6 py-3 text-sm font-bold text-white transition hover:bg-[#1E7AEB]">
              Call Us — {phone}
            </a>
          </div>
        </div>
        <div class="rounded-2xl border border-[#E3E8F1] bg-[#F4F6FA] p-8 text-center">
          <div class="mx-auto mb-4 flex h-24 w-24 items-center justify-center rounded-full bg-[#0B2545] text-4xl">👨‍👦</div>
          <p class="text-lg font-bold text-[#0B2545]">Dillon & Dad</p>
          <p class="mt-1 text-sm text-[#44506A]">Father-Son Team · Pewaukee, WI</p>
          <p class="mt-4 text-sm italic text-[#44506A]">"We treat every client like a neighbor — because in most cases, they are."</p>
        </div>
      </div>
    </div>
  </section>

  <!-- WHY LOCAL MATTERS -->
  <section class="bg-[#F4F6FA] px-4 py-20 md:py-24">
    <div class="mx-auto max-w-5xl">
      <div class="mb-12 text-center">
        <p class="mb-2 text-xs font-semibold uppercase tracking-widest text-[#2E8BFF]">Why It Matters</p>
        <h2 class="text-3xl font-bold text-[#0B2545] md:text-4xl">Local Makes a Difference</h2>
        <p class="mx-auto mt-4 max-w-xl text-base text-[#44506A]">Working with a local team isn't just nice — it changes the quality of the work.</p>
      </div>
      <div class="grid gap-6 md:grid-cols-3">
        <div class="rounded-2xl bg-white p-8 shadow-sm">
          <div class="mb-4 text-3xl">📍</div>
          <h3 class="text-lg font-bold text-[#0B2545]">We Know Your Market</h3>
          <p class="mt-2 text-sm leading-relaxed text-[#44506A]">We live in Pewaukee. We know what Wisconsin homeowners search for, what they trust, and what makes them call. That context makes every website and SEO strategy we build more effective.</p>
        </div>
        <div class="rounded-2xl bg-white p-8 shadow-sm">
          <div class="mb-4 text-3xl">📞</div>
          <h3 class="text-lg font-bold text-[#0B2545]">You Can Actually Reach Us</h3>
          <p class="mt-2 text-sm leading-relaxed text-[#44506A]">No ticket system. No offshore support team. You call or text us directly. If something's wrong, we fix it fast — because your business running smoothly is how our business grows.</p>
        </div>
        <div class="rounded-2xl bg-white p-8 shadow-sm">
          <div class="mb-4 text-3xl">🤝</div>
          <h3 class="text-lg font-bold text-[#0B2545]">We're Building Long-Term</h3>
          <p class="mt-2 text-sm leading-relaxed text-[#44506A]">We're not trying to sign you up and disappear. We want to be your digital partner for years — the team you call when you want to grow, launch something new, or just fix what's broken.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- VALUES -->
  <section class="px-4 py-20 md:py-24">
    <div class="mx-auto max-w-5xl">
      <div class="mb-12 text-center">
        <p class="mb-2 text-xs font-semibold uppercase tracking-widest text-[#2E8BFF]">How We Operate</p>
        <h2 class="text-3xl font-bold text-[#0B2545] md:text-4xl">Our Non-Negotiables</h2>
      </div>
      <div class="grid gap-6 md:grid-cols-2">
        <div class="flex gap-5 rounded-2xl border border-[#E3E8F1] p-6">
          <span class="text-2xl">✅</span>
          <div>
            <h3 class="font-bold text-[#0B2545]">Honesty First</h3>
            <p class="mt-1 text-sm leading-relaxed text-[#44506A]">If something isn't working, we'll tell you. If a service isn't right for your business, we'll say so. We'd rather lose a sale than give you bad advice.</p>
          </div>
        </div>
        <div class="flex gap-5 rounded-2xl border border-[#E3E8F1] p-6">
          <span class="text-2xl">⚡</span>
          <div>
            <h3 class="font-bold text-[#0B2545]">Speed Matters</h3>
            <p class="mt-1 text-sm leading-relaxed text-[#44506A]">Most clients are live within 2–3 weeks. We don't drag projects out for months. When we say 30 days, we mean it.</p>
          </div>
        </div>
        <div class="flex gap-5 rounded-2xl border border-[#E3E8F1] p-6">
          <span class="text-2xl">💰</span>
          <div>
            <h3 class="font-bold text-[#0B2545]">Fair Pricing</h3>
            <p class="mt-1 text-sm leading-relaxed text-[#44506A]">One monthly price covers everything. No surprise invoices, no upsells you didn't ask for, no confusing add-ons.</p>
          </div>
        </div>
        <div class="flex gap-5 rounded-2xl border border-[#E3E8F1] p-6">
          <span class="text-2xl">📈</span>
          <div>
            <h3 class="font-bold text-[#0B2545]">Results You Can See</h3>
            <p class="mt-1 text-sm leading-relaxed text-[#44506A]">We track calls, leads, and rankings — not just "impressions." If the numbers aren't moving, we figure out why and fix it.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FINAL CTA -->
  <section class="bg-[#0B2545] px-4 py-20 md:py-24">
    <div class="mx-auto max-w-3xl text-center">
      <h2 class="text-3xl font-bold text-white md:text-4xl">Ready to Work With a Team You Can Trust?</h2>
      <p class="mx-auto mt-5 max-w-xl text-lg text-[#8EA8C3]">Give us a call or fill out the form. We'll take a look at your current online presence and tell you honestly what it would take to get your phone ringing more.</p>
      <div class="mt-8 flex flex-col items-center gap-4 sm:flex-row sm:justify-center">
        <a href={phoneHref} class="inline-flex items-center gap-2 rounded-xl bg-[#2E8BFF] px-8 py-4 text-base font-bold text-white transition hover:bg-[#1E7AEB]">
          Call Now — {phone}
        </a>
        <a href="/contact" class="inline-flex rounded-xl border-2 border-white/30 px-8 py-4 text-base font-semibold text-white transition hover:border-white hover:bg-white/10">
          Get a Free Quote
        </a>
      </div>
    </div>
  </section>

</BaseLayout>
