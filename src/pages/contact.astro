---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';

const pageTitle = 'Contact | North Star Digital';
const description =
  'Book a free consult with North Star Digital. Share your website, CRM, SEO, or automation needs and start building a stronger growth system.';
---

<BaseLayout title={pageTitle} description={description} path="/contact">
  <section class="px-4 pb-16 pt-16 md:px-6 md:pb-20 md:pt-20">
    <div class="mx-auto w-full max-w-6xl">
      <SectionHeading
        eyebrow="Contact"
        title="Book a free consult"
        description="Tell us what you are working on and we will follow up with next steps."
      />
    </div>
  </section>

  <section class="bg-[#F4F6FA] px-4 py-20 md:px-6">
    <div class="mx-auto w-full max-w-3xl rounded-2xl border border-[#DEE6F2] bg-white p-8 shadow-sm">
      <!-- TODO: Replace TODO_FORMSPREE_ID with your real form ID.
           Steps: sign up at formspree.io → New Form → copy the ID from the endpoint URL. -->
      <form action="https://formspree.io/f/TODO_FORMSPREE_ID" method="POST" class="space-y-5">
        <div class="grid gap-5 md:grid-cols-2">
          <div>
            <label for="name" class="mb-1 block text-sm font-medium text-[#0B2545]">Name</label>
            <input id="name" name="Name" type="text" required class="w-full rounded-lg border border-[#D7DFEC] px-3 py-2.5 text-sm text-[#1A1F2E]" />
          </div>
          <div>
            <label for="email" class="mb-1 block text-sm font-medium text-[#0B2545]">Email</label>
            <input id="email" name="Email" type="email" required class="w-full rounded-lg border border-[#D7DFEC] px-3 py-2.5 text-sm text-[#1A1F2E]" />
          </div>
          <div>
            <label for="phone" class="mb-1 block text-sm font-medium text-[#0B2545]">Phone (optional)</label>
            <input id="phone" name="Phone" type="tel" class="w-full rounded-lg border border-[#D7DFEC] px-3 py-2.5 text-sm text-[#1A1F2E]" />
          </div>
          <div>
            <label for="business-name" class="mb-1 block text-sm font-medium text-[#0B2545]">Business Name</label>
            <input id="business-name" name="Business Name" type="text" required class="w-full rounded-lg border border-[#D7DFEC] px-3 py-2.5 text-sm text-[#1A1F2E]" />
          </div>
        </div>
        <div>
          <label for="help-with" class="mb-1 block text-sm font-medium text-[#0B2545]">What you need help with</label>
          <select id="help-with" name="What you need help with" required class="w-full rounded-lg border border-[#D7DFEC] px-3 py-2.5 text-sm text-[#1A1F2E]">
            <option value="">Select an option</option>
            <option value="Website">Website</option>
            <option value="CRM">CRM</option>
            <option value="SEO">SEO</option>
            <option value="Automation">Automation</option>
            <option value="Not sure">Not sure</option>
          </select>
        </div>
        <div>
          <label for="message" class="mb-1 block text-sm font-medium text-[#0B2545]">Message</label>
          <textarea
            id="message"
            name="Message"
            rows="6"
            required
            class="w-full rounded-lg border border-[#D7DFEC] px-3 py-2.5 text-sm text-[#1A1F2E]"
          ></textarea>
        </div>
        <button
          type="submit"
          class="inline-flex rounded-xl bg-[#2E8BFF] px-5 py-3 text-sm font-semibold text-white transition hover:bg-[#1E7AEB]"
        >
          Send message
        </button>
      </form>
    </div>
  </section>
</BaseLayout>
