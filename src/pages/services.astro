---
import BaseLayout from '../layouts/BaseLayout.astro';

const pageTitle = 'Services | North Star Digital — Pewaukee, WI';
const description =
  'North Star Digital offers websites, local SEO, CRM setup, and marketing automation for Wisconsin small businesses. Starting at $299/month. Serving Pewaukee, Waukesha, and Milwaukee.';

const phone = '(262) 254-0128';
const phoneHref = 'tel:+12622540128';

const services = [
  {
    icon: '🖥️',
    title: 'High-Converting Websites',
    tagline: 'A website that actually gets you calls',
    description: 'Most small business websites look outdated, load slow, and don\'t convert visitors into leads. We build fast, mobile-ready websites designed around one goal: getting your phone to ring. Every page is optimized for local search and built to make a great first impression.',
    includes: [
      'Custom design built for your industry',
      'Mobile-first, fast-loading pages',
      'Phone call-focused CTAs throughout',
      'Basic SEO setup included',
      'Hosting included in monthly plans',
      'Delivered in 2–3 weeks'
    ],
    whoFor: 'Contractors, plumbers, landscapers, home service businesses, local retailers — anyone who needs a professional online presence that actually works.',
    price: 'Starting at $399 one-time or included in monthly plans',
    cta: 'Get a Free Website Mockup'
  },
  {
    icon: '📍',
    title: 'Local SEO',
    tagline: 'Show up when customers search for you',
    description: 'When someone in Waukesha searches "plumber near me" or "landscaper Pewaukee" — you want to be at the top. We optimize your website and Google Business Profile so local customers find you first, not your competitors.',
    includes: [
      'Google Business Profile setup & optimization',
      'Local keyword research for your area',
      'On-page SEO for all website pages',
      'Citation building (directories, maps)',
      'Monthly ranking report',
      'Review generation strategy'
    ],
    whoFor: 'Any local service business that wants to rank higher on Google and get more calls from customers in their area.',
    price: 'Included in Growth and Pro plans',
    cta: 'Start Ranking Locally'
  },
  {
    icon: '📋',
    title: 'CRM & Lead Management',
    tagline: 'Never lose a lead again',
    description: 'Most small businesses lose 50% of their leads simply because nobody followed up. We set up a simple CRM system that automatically tracks every inquiry, sends follow-up texts and emails, and keeps your pipeline organized — so you close more jobs without extra work.',
    includes: [
      'CRM setup and configuration',
      'Lead capture from website form',
      'Automated follow-up sequences (text + email)',
      'Pipeline tracking dashboard',
      'Appointment reminders',
      'Monthly pipeline review'
    ],
    whoFor: 'Service businesses getting inbound leads who want to stop losing jobs to slow follow-up or disorganized pipelines.',
    price: 'Included in Growth and Pro plans',
    cta: 'Stop Losing Leads'
  },
  {
    icon: '⚡',
    title: 'Marketing Automation',
    tagline: 'Your business running while you sleep',
    description: 'Stop doing manually what a system can do automatically. We build AI-powered workflows that send review requests, follow up with cold leads, notify you of new inquiries, and keep your customers engaged — 24 hours a day, 7 days a week.',
    includes: [
      'Automated review request campaigns',
      'Lead nurture sequences',
      'Missed call text-back automation',
      'Appointment confirmation & reminders',
      'Monthly performance reporting',
      'Custom workflows for your business'
    ],
    whoFor: 'Business owners who are too busy to follow up manually and want systems that run themselves.',
    price: 'Included in Pro plan',
    cta: 'Automate Your Business'
  }
];
---

<BaseLayout title={pageTitle} description={description} path="/services">

  <!-- HERO -->
  <section class="bg-[#0B2545] px-4 py-16 md:py-20">
    <div class="mx-auto max-w-4xl text-center">
      <p class="mb-3 text-xs font-semibold uppercase tracking-widest text-[#2E8BFF]">What We Do</p>
      <h1 class="text-4xl font-bold text-white md:text-5xl">Everything You Need to Grow Online</h1>
      <p class="mx-auto mt-5 max-w-2xl text-lg text-[#8EA8C3]">
        One local team. One monthly price. Websites, SEO, CRM, and automation — all working together to get your phone ringing more.
      </p>
      <div class="mt-8 flex flex-col items-center gap-4 sm:flex-row sm:justify-center">
        <a href={phoneHref} class="inline-flex items-center gap-2 rounded-xl bg-[#2E8BFF] px-8 py-4 text-base font-bold text-white transition hover:bg-[#1E7AEB]">
          Call Now — {phone}
        </a>
        <a href="/contact" class="inline-flex rounded-xl border-2 border-white/30 px-8 py-4 text-base font-semibold text-white transition hover:border-white hover:bg-white/10">
          Get a Free Quote
        </a>
      </div>
    </div>
  </section>

  <!-- SERVICES -->
  <section class="px-4 py-20 md:py-24">
    <div class="mx-auto max-w-5xl space-y-16">
      {services.map((service, i) => (
        <div class={`grid gap-10 md:grid-cols-2 md:items-start ${i % 2 === 1 ? 'md:[&>*:first-child]:order-2' : ''}`}>
          <div>
            <div class="mb-4 text-4xl">{service.icon}</div>
            <p class="text-xs font-semibold uppercase tracking-widest text-[#2E8BFF]">{service.tagline}</p>
            <h2 class="mt-2 text-3xl font-bold text-[#0B2545]">{service.title}</h2>
            <p class="mt-4 text-base leading-relaxed text-[#44506A]">{service.description}</p>
            <p class="mt-4 text-sm font-semibold text-[#44506A]"><span class="text-[#0B2545]">Best for:</span> {service.whoFor}</p>
            <p class="mt-3 text-sm font-bold text-[#2E8BFF]">{service.price}</p>
            <a href={phoneHref} class="mt-6 inline-flex rounded-xl bg-[#2E8BFF] px-6 py-3 text-sm font-bold text-white transition hover:bg-[#1E7AEB]">
              {service.cta}
            </a>
          </div>
          <div class="rounded-2xl border border-[#E3E8F1] bg-[#F4F6FA] p-8">
            <p class="mb-4 text-sm font-bold text-[#0B2545]">What's included:</p>
            <ul class="space-y-3">
              {service.includes.map((item) => (
                <li class="flex items-start gap-3 text-sm text-[#44506A]">
                  <span class="mt-0.5 text-[#2E8BFF]">✓</span>
                  {item}
                </li>
              ))}
            </ul>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- PRICING SUMMARY -->
  <section class="bg-[#F4F6FA] px-4 py-20 md:py-24">
    <div class="mx-auto max-w-5xl">
      <div class="mb-12 text-center">
        <p class="mb-2 text-xs font-semibold uppercase tracking-widest text-[#2E8BFF]">Simple Pricing</p>
        <h2 class="text-3xl font-bold text-[#0B2545] md:text-4xl">One Price. Everything Included.</h2>
        <p class="mx-auto mt-4 max-w-xl text-base text-[#44506A]">No à la carte confusion. Pick a plan and get everything in it.</p>
      </div>
      <div class="grid gap-6 md:grid-cols-3">
        <div class="rounded-2xl border border-[#E3E8F1] bg-white p-8 shadow-sm">
          <p class="text-xs font-semibold uppercase tracking-widest text-[#2E8BFF]">Starter</p>
          <p class="mt-3 text-4xl font-bold text-[#0B2545]">$299<span class="text-lg font-normal text-[#44506A]">/mo</span></p>
          <ul class="mt-6 space-y-2 text-sm text-[#304059]">
            <li>✓ Website + hosting</li>
            <li>✓ Mobile-ready</li>
            <li>✓ Basic SEO</li>
            <li>✓ Email security</li>
            <li>✓ Monthly report</li>
          </ul>
          <a href={phoneHref} class="mt-8 block rounded-xl border border-[#2E8BFF] py-3 text-center text-sm font-bold text-[#2E8BFF] transition hover:bg-[#F0F6FF]">Call to Start</a>
        </div>
        <div class="relative rounded-2xl border-2 border-[#2E8BFF] bg-white p-8 shadow-lg">
          <p class="absolute -top-3 left-1/2 -translate-x-1/2 rounded-full bg-[#2E8BFF] px-4 py-1 text-xs font-bold text-white">Most Popular</p>
          <p class="text-xs font-semibold uppercase tracking-widest text-[#2E8BFF]">Growth</p>
          <p class="mt-3 text-4xl font-bold text-[#0B2545]">$499<span class="text-lg font-normal text-[#44506A]">/mo</span></p>
          <ul class="mt-6 space-y-2 text-sm text-[#304059]">
            <li>✓ Everything in Starter</li>
            <li>✓ Local SEO</li>
            <li>✓ CRM + lead tracking</li>
            <li>✓ Automated follow-up</li>
            <li>✓ Monthly strategy call</li>
          </ul>
          <a href={phoneHref} class="mt-8 block rounded-xl bg-[#2E8BFF] py-3 text-center text-sm font-bold text-white transition hover:bg-[#1E7AEB]">Call to Start</a>
        </div>
        <div class="rounded-2xl border border-[#E3E8F1] bg-white p-8 shadow-sm">
          <p class="text-xs font-semibold uppercase tracking-widest text-[#2E8BFF]">Pro</p>
          <p class="mt-3 text-4xl font-bold text-[#0B2545]">$999<span class="text-lg font-normal text-[#44506A]">/mo</span></p>
          <ul class="mt-6 space-y-2 text-sm text-[#304059]">
            <li>✓ Everything in Growth</li>
            <li>✓ Full AI automation</li>
            <li>✓ Custom integrations</li>
            <li>✓ Priority support</li>
            <li>✓ Dedicated manager</li>
          </ul>
          <a href={phoneHref} class="mt-8 block rounded-xl border border-[#2E8BFF] py-3 text-center text-sm font-bold text-[#2E8BFF] transition hover:bg-[#F0F6FF]">Call to Start</a>
        </div>
      </div>
      <p class="mt-8 text-center text-sm text-[#44506A]">Not sure which plan? <a href={phoneHref} class="font-semibold text-[#2E8BFF] hover:underline">Call us — {phone}</a> and we'll tell you honestly.</p>
    </div>
  </section>

  <!-- FINAL CTA -->
  <section class="bg-[#0B2545] px-4 py-20 md:py-24">
    <div class="mx-auto max-w-3xl text-center">
      <h2 class="text-3xl font-bold text-white md:text-4xl">Ready to Get Started?</h2>
      <p class="mx-auto mt-5 max-w-xl text-lg text-[#8EA8C3]">Call us today for a free consultation. We'll look at your current online presence and tell you exactly what it would take to get more calls coming in.</p>
      <div class="mt-8 flex flex-col items-center gap-4 sm:flex-row sm:justify-center">
        <a href={phoneHref} class="inline-flex items-center gap-2 rounded-xl bg-[#2E8BFF] px-8 py-4 text-base font-bold text-white transition hover:bg-[#1E7AEB]">
          Call Now — {phone}
        </a>
        <a href="/contact" class="inline-flex rounded-xl border-2 border-white/30 px-8 py-4 text-base font-semibold text-white transition hover:border-white hover:bg-white/10">
          Get a Free Quote
        </a>
      </div>
    </div>
  </section>

</BaseLayout>
