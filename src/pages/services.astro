---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import CTA from '../components/CTA.astro';
import { services } from '../data/site';

const pageTitle = 'Services | North Star Digital';
const description =
  'Explore North Star Digital services: Website Design & Development, CRM Systems, SEO Strategy, and Marketing Automations for small and mid-sized businesses.';
---

<BaseLayout title={pageTitle} description={description} path="/services">
  <section class="px-4 pb-16 pt-16 md:px-6 md:pb-20 md:pt-20">
    <div class="mx-auto w-full max-w-6xl">
      <SectionHeading
        eyebrow="Services"
        title="Digital systems built for measurable business growth"
        description="Each service is designed to strengthen your full lead-to-client journey, from first impression to long-term follow-up."
      />
    </div>
  </section>

  <section class="bg-[#F4F6FA] px-4 py-20 md:px-6">
    <div class="mx-auto w-full max-w-6xl space-y-8">
      {services.map((service) => (
        <article id={service.id} class="rounded-2xl border border-[#DEE6F2] bg-white p-8 shadow-sm">
          <h2 class="text-2xl font-semibold text-[#0B2545] md:text-3xl">{service.title}</h2>
          <p class="mt-3 text-base text-[#44506A]">{service.shortDescription}</p>
          <div class="mt-8 grid gap-6 md:grid-cols-2">
            <div class="space-y-3">
              <h3 class="text-sm font-semibold uppercase tracking-wide text-[#0B2545]">What it is</h3>
              <p class="text-sm leading-relaxed text-[#44506A]">{service.whatItIs}</p>
            </div>
            <div class="space-y-3">
              <h3 class="text-sm font-semibold uppercase tracking-wide text-[#0B2545]">Who it is for</h3>
              <p class="text-sm leading-relaxed text-[#44506A]">{service.whoItsFor}</p>
            </div>
            <div class="space-y-3">
              <h3 class="text-sm font-semibold uppercase tracking-wide text-[#0B2545]">What's included</h3>
              <ul class="space-y-2 text-sm text-[#44506A]">
                {service.included.map((item) => <li>- {item}</li>)}
              </ul>
            </div>
            <div class="space-y-3">
              <h3 class="text-sm font-semibold uppercase tracking-wide text-[#0B2545]">Expected outcomes</h3>
              <ul class="space-y-2 text-sm text-[#44506A]">
                {service.outcomes.map((item) => <li>- {item}</li>)}
              </ul>
            </div>
          </div>
        </article>
      ))}
    </div>
  </section>

  <CTA
    title="Need help choosing the right service mix?"
    description="Book a free consult and we will map your highest-impact priorities based on your current stage of growth."
  />
</BaseLayout>
